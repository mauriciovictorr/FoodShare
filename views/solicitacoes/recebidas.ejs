<%- include('../partials/app-shell-start') %>

<div class="app-page">
  <article class="app-page-panel">
    <% if (solicitacoes.length === 0) { %>
      <%- include('../partials/home-empty-state', {
        variant: 'amber',
        icon: 'mark_email_unread',
        title: 'Nenhuma solicitação recebida',
        description: 'Quando alguém pedir um dos seus itens, o pedido aparece aqui para você aceitar ou recusar.',
        actionLabel: 'Ver minhas doações',
        actionHref: '/doacoes'
      }) %>
    <% } else { %>
      <ul class="home-requests">
        <% solicitacoes.forEach(function(solic) {
          const itemLabel = solic.doacao.itens && solic.doacao.itens[0]
            ? solic.doacao.itens[0].nome
            : 'Doação';
          const statusLabel = solicitationDisplayStatus(solic.status);
        %>
          <li class="home-request">
            <div class="home-request__info">
              <p class="home-request__title"><%= itemLabel %> · <%= solic.quantidade %> un</p>
              <p class="home-request__meta">
                <%= solic.usuario.nome %> · <%= timeAgo(solic.createdAt) %>
                <% if (solic.observacoes) { %> · "<%= solic.observacoes %>"<% } %>
              </p>
            </div>

            <% if (solic.status === 'pendente') { %>
              <div class="home-request__actions home-request__actions--desktop">
                <form action="/solicitacoes/<%= solic.id %>/aceitar" method="POST">
                  <button type="submit" class="home-btn-secondary home-btn-secondary--sm">Aceitar</button>
                </form>
                <form action="/solicitacoes/<%= solic.id %>/recusar" method="POST">
                  <button type="submit" class="home-btn-secondary home-btn-secondary--sm">Recusar</button>
                </form>
              </div>
              <div class="home-request__actions home-request__actions--mobile">
                <form action="/solicitacoes/<%= solic.id %>/aceitar" method="POST">
                  <button type="submit" class="home-icon-action" aria-label="Aceitar">
                    <%- include('../partials/app-icon', { icon: 'check_circle', size: 'action' }) %>
                  </button>
                </form>
                <form action="/solicitacoes/<%= solic.id %>/recusar" method="POST">
                  <button type="submit" class="home-icon-action" aria-label="Recusar">
                    <%- include('../partials/app-icon', { icon: 'cancel', size: 'action' }) %>
                  </button>
                </form>
              </div>
            <% } else { %>
              <span class="home-pill home-pill--<%= statusLabel %>"><%= statusLabel %></span>
            <% } %>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </article>
</div>

<%- include('../partials/app-shell-end') %>

<div
  class="feedback-modal-overlay doacao-detail-overlay solicitacao-detail-overlay"
  id="solicitacao-detail-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="solicitacao-detail-title"
  aria-hidden="true"
>
  <div class="feedback-modal doacao-detail-modal solicitacao-detail-modal">
    <button type="button" class="doacao-detail-modal__close" data-solicitacao-detail-close aria-label="Fechar">
      <%- include('app-icon', { icon: 'close', size: 'chevron' }) %>
    </button>
    <div class="doacao-detail-modal__body" id="solicitacao-detail-body"></div>
    <div class="doacao-detail-modal__actions" id="solicitacao-detail-actions"></div>
  </div>
</div>

<%- include('../partials/header') %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <div class="bg-white dark:bg-[#111111] rounded-2xl border border-neutral-200 dark:border-neutral-800 p-6 md:p-8 shadow-sm">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-neutral-900 dark:text-white mb-2">Nova Doação</h1>
      <p class="text-neutral-500 text-sm">Adicione os itens alimentícios que você deseja doar. Você pode incluir vários itens no mesmo pacote de doação.</p>
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-red-600 dark:text-red-400 p-4 rounded-xl mb-6">
        <ul class="list-disc list-inside text-sm">
          <% errors.forEach(err => { %>
            <li><%= err.message %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form method="POST" action="/doacoes/nova" id="doacaoForm">
      
      <!-- Observações Gerais -->
      <div class="mb-8">
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Observações Gerais (Opcional)</label>
        <textarea name="observacoes" rows="2" class="w-full bg-transparent border border-neutral-300 dark:border-neutral-700 rounded-xl px-4 py-3 text-neutral-900 dark:text-white focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors" placeholder="Ex: Todos os itens estão com embalagem fechada..."><%= old && old.observacoes ? old.observacoes : '' %></textarea>
      </div>

      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-neutral-900 dark:text-white">Itens da Doação</h2>
        <button type="button" id="btnAdicionarItem" class="text-sm font-medium text-green-600 dark:text-green-400 hover:text-green-700 dark:hover:text-green-300 bg-green-50 dark:bg-green-500/10 px-3 py-1.5 rounded-lg flex items-center gap-1.5 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
          Adicionar Item
        </button>
      </div>

      <!-- Container dinâmico de itens -->
      <div id="itensContainer" class="space-y-4">
        <!-- O JS vai injetar os itens aqui. Vamos deixar o primeiro por padrão. -->
      </div>

      <div class="mt-8 pt-6 border-t border-neutral-200 dark:border-neutral-800 flex justify-end gap-3">
        <a href="/" class="px-5 py-2.5 text-sm font-medium text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors">Cancelar</a>
        <button type="submit" class="px-5 py-2.5 bg-green-500 hover:bg-green-600 text-white text-sm font-medium rounded-xl shadow-lg shadow-green-500/20 transition-all hover:-translate-y-0.5">
          Publicar Doação
        </button>
      </div>
    </form>
  </div>
</div>

<template id="itemTemplate">
  <div class="item-doacao bg-neutral-50 dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700 rounded-xl p-5 relative group">
    <button type="button" class="btnRemoverItem absolute top-4 right-4 text-neutral-400 hover:text-red-500 transition-colors opacity-0 group-hover:opacity-100" title="Remover item">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1">Nome do Alimento *</label>
        <input type="text" data-name="nome" required class="w-full bg-white dark:bg-[#1a1a1a] border border-neutral-300 dark:border-neutral-700 rounded-lg px-3 py-2 text-sm text-neutral-900 dark:text-white focus:ring-2 focus:ring-green-500" placeholder="Ex: Arroz Integral 5kg">
      </div>
      <div>
        <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1">Categoria *</label>
        <select data-name="categoria" required class="w-full bg-white dark:bg-[#1a1a1a] border border-neutral-300 dark:border-neutral-700 rounded-lg px-3 py-2 text-sm text-neutral-900 dark:text-white focus:ring-2 focus:ring-green-500">
          <option value="">Selecione...</option>
          <option value="grãos">Grãos e Cereais</option>
          <option value="laticínios">Laticínios</option>
          <option value="frutas">Frutas e Vegetais</option>
          <option value="carnes">Carnes e Proteínas</option>
          <option value="industrializados">Industrializados</option>
          <option value="outros">Outros</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1">Quantidade *</label>
        <input type="number" data-name="quantidade" min="1" required class="w-full bg-white dark:bg-[#1a1a1a] border border-neutral-300 dark:border-neutral-700 rounded-lg px-3 py-2 text-sm text-neutral-900 dark:text-white focus:ring-2 focus:ring-green-500" placeholder="Ex: 5">
      </div>
      <div>
        <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1">Validade *</label>
        <input type="date" data-name="validade" required class="w-full bg-white dark:bg-[#1a1a1a] border border-neutral-300 dark:border-neutral-700 rounded-lg px-3 py-2 text-sm text-neutral-900 dark:text-white focus:ring-2 focus:ring-green-500">
      </div>
    </div>
  </div>
</template>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('itensContainer');
    const template = document.getElementById('itemTemplate');
    const btnAdd = document.getElementById('btnAdicionarItem');
    let itemCount = 0;

    function adicionarItem() {
      const clone = template.content.cloneNode(true);
      const itemDiv = clone.querySelector('.item-doacao');
      
      // Atualizar os names dos inputs para formar o array: itens[0][nome], itens[0][quantidade]...
      const inputs = itemDiv.querySelectorAll('[data-name]');
      inputs.forEach(input => {
        input.name = `itens[${itemCount}][${input.dataset.name}]`;
      });

      // Se for o primeiro item, escondemos o botão de remover
      const btnRemover = itemDiv.querySelector('.btnRemoverItem');
      if (itemCount === 0) {
        btnRemover.style.display = 'none';
      } else {
        btnRemover.addEventListener('click', () => {
          itemDiv.remove();
          recalcularIndices();
        });
      }

      container.appendChild(clone);
      itemCount++;
    }

    function recalcularIndices() {
      const itens = container.querySelectorAll('.item-doacao');
      itemCount = 0;
      itens.forEach((itemDiv, index) => {
        const inputs = itemDiv.querySelectorAll('[data-name]');
        inputs.forEach(input => {
          input.name = `itens[${index}][${input.dataset.name}]`;
        });
        itemCount++;
      });
    }

    btnAdd.addEventListener('click', adicionarItem);

    // Adiciona o primeiro item automaticamente
    adicionarItem();
  });
</script>

<%- include('../partials/footer') %>

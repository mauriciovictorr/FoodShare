datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id            String         @id @default(uuid())
  nome          String
  email         String         @unique
  senha         String
  telefone      String
  role          String         @default("doador") // doador, receptor, admin
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  doacoes       Doacao[]
  solicitacoes  Solicitacao[]
  notificacoesLidas NotificacaoLida[]
  passwordResetTokens PasswordResetToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Doacao {
  id           String        @id @default(uuid())
  status       String        @default("disponivel") // disponivel, reservado, entregue
  observacoes  String?
  usuarioId    String
  usuario      Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  itens        ItemDoacao[]
  solicitacoes Solicitacao[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ItemDoacao {
  id         String   @id @default(uuid())
  nome       String
  quantidade Int
  categoria  String
  validade   DateTime
  doacaoId   String
  doacao     Doacao   @relation(fields: [doacaoId], references: [id], onDelete: Cascade)
}

model Solicitacao {
  id          String   @id @default(uuid())
  quantidade  Int
  status      String   @default("pendente") // pendente, aprovado, recusado, cancelado
  observacoes String?
  doacaoId    String
  doacao      Doacao   @relation(fields: [doacaoId], references: [id], onDelete: Cascade)
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model NotificacaoLida {
  id            String   @id @default(uuid())
  usuarioId     String
  solicitacaoId String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([usuarioId, solicitacaoId])
  @@index([usuarioId])
}

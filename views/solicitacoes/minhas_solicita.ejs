<%- include('../partials/app-shell-start') %>

<div class="app-page solicitacoes-minhas-page">
  <% if (typeof showReceptorHero !== 'undefined' && showReceptorHero) { %>
    <div class="receptor-hero-mobile receptor-hero-mobile--page">
      <%- include('../partials/receptor-hero-card', {
        totalSolicitadas: totalSolicitadas,
        totalRecebidas: totalRecebidas,
        totalPendentes: totalPendentes,
        mesAtual: mesAtual
      }) %>
    </div>
  <% } %>

  <article class="app-page-panel solicitacoes-minhas-panel">
    <% if (solicitacoes.length === 0) { %>
      <%- include('../partials/home-empty-state', {
        variant: 'amber',
        icon: 'hourglass_top',
        title: 'Nenhuma solicitação encontrada',
        description: 'Você ainda não solicitou nenhuma doação. Explore o que está disponível na comunidade.',
        actionLabel: 'Ver doações disponíveis',
        actionHref: '/doacoes'
      }) %>
    <% } else { %>
      <div class="solicitacoes-toolbar">
        <p class="solicitacoes-toolbar__count" data-minhas-solicitacoes-count>
          <%= solicitacoes.length %> <%= solicitacoes.length === 1 ? 'solicitação' : 'solicitações' %>
        </p>
        <div class="app-filter-chips solicitacoes-filters" role="group" aria-label="Filtrar solicitações">
          <button type="button" class="app-filter-chip is-active" data-minhas-solicitacao-filter="todos">Todos</button>
          <button type="button" class="app-filter-chip" data-minhas-solicitacao-filter="pendente">Pendentes</button>
          <button type="button" class="app-filter-chip" data-minhas-solicitacao-filter="aprovado">Aprovados</button>
          <button type="button" class="app-filter-chip" data-minhas-solicitacao-filter="recusado">Recusados</button>
          <button type="button" class="app-filter-chip" data-minhas-solicitacao-filter="cancelado">Cancelados</button>
        </div>
      </div>

      <ul class="home-requests" data-minhas-solicitacoes-list>
        <% solicitacoes.forEach(function(solic) {
          const itemLabel = solic.doacao.itens && solic.doacao.itens[0]
            ? solic.doacao.itens[0].nome
            : 'Doação';
          const doadorNome = (solic.doacao.usuario && solic.doacao.usuario.nome) || 'Doador';
          const pillKey = solicitationPillKey(solic.status);
          const pillLabel = solicitationPillLabel(solic.status);
        %>
          <li
            class="home-request home-request--readonly home-request--clickable"
            data-solicitacao-id="<%= solic.id %>"
            data-status="<%= solic.status %>"
            role="button"
            tabindex="0"
            aria-label="Ver detalhes: <%= itemLabel %>"
          >
            <div class="home-request__info">
              <p class="home-request__title"><%= itemLabel %> · <%= solic.quantidade %> un</p>
              <p class="home-request__meta">
                <%= doadorNome %> · <%= timeAgo(solic.createdAt) %>
                <% if (solic.observacoes) { %> · <%= solic.observacoes %><% } %>
              </p>
            </div>
            <div class="home-request__aside">
              <span class="home-pill home-pill--<%= pillKey %>"><%= pillLabel %></span>
            </div>
          </li>
        <% }); %>
      </ul>

      <p class="solicitacoes-filter-empty" data-minhas-solicitacoes-filter-empty hidden>
        Nenhuma solicitação neste filtro.
      </p>
    <% } %>
  </article>
</div>

<%- include('../partials/solicitacao-detail-modal') %>
<%- include('../partials/solicitacoes-detalhe-data') %>
<script src="/js/solicitacoes-minhas.js"></script>

<%- include('../partials/app-shell-end') %>

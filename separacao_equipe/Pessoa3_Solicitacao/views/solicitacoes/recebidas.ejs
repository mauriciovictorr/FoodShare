<%- include('../partials/header') %>

<div class="max-w-5xl mx-auto px-4 py-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-neutral-900 dark:text-white mb-1">Solicitações Recebidas</h1>
    <p class="text-neutral-500 text-sm">Gerencie os pedidos feitos para as suas doações.</p>
  </div>

  <% if (solicitacoes.length === 0) { %>
    <div class="bg-neutral-50 dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700 rounded-2xl p-12 text-center">
      <div class="w-16 h-16 bg-neutral-100 dark:bg-neutral-800 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
        📥
      </div>
      <h3 class="text-lg font-medium text-neutral-900 dark:text-white mb-2">Nenhuma solicitação recebida</h3>
      <p class="text-neutral-500 text-sm mb-6">Suas doações ainda não receberam pedidos.</p>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% solicitacoes.forEach(solic => { %>
        <div class="bg-white dark:bg-[#111111] border border-neutral-200 dark:border-neutral-800 rounded-2xl p-6 shadow-sm flex flex-col h-full">
          
          <div class="flex items-start justify-between mb-4">
            <div>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border mb-3
                <%= solic.status === 'pendente' ? 'bg-yellow-50 text-yellow-700 border-yellow-200 dark:bg-yellow-500/10 dark:text-yellow-400 dark:border-yellow-500/20' : '' %>
                <%= solic.status === 'aprovado' ? 'bg-green-50 text-green-700 border-green-200 dark:bg-green-500/10 dark:text-green-400 dark:border-green-500/20' : '' %>
                <%= solic.status === 'recusado' ? 'bg-red-50 text-red-700 border-red-200 dark:bg-red-500/10 dark:text-red-400 dark:border-red-500/20' : '' %>
                <%= solic.status === 'cancelado' ? 'bg-neutral-100 text-neutral-600 border-neutral-300 dark:bg-neutral-800 dark:text-neutral-400 dark:border-neutral-700' : '' %>
              ">
                Status: <%= solic.status.charAt(0).toUpperCase() + solic.status.slice(1) %>
              </span>
              <h3 class="font-semibold text-neutral-900 dark:text-white flex items-center gap-2">
                Solicitante: <%= solic.usuario.nome %>
              </h3>
              <p class="text-xs text-neutral-500 mt-1">Contato: <%= solic.usuario.email %></p>
            </div>
            <span class="text-xs text-neutral-400"><%= new Date(solic.createdAt).toLocaleDateString() %></span>
          </div>

          <div class="bg-neutral-50 dark:bg-neutral-800/50 rounded-xl p-4 mb-4 flex-grow border border-neutral-100 dark:border-neutral-800">
            <div class="mb-3">
              <span class="text-xs font-medium text-neutral-500 block mb-1">Pacote Solicitado (ID):</span>
              <span class="font-mono text-sm text-neutral-700 dark:text-neutral-300"><%= solic.doacao.id.substring(0,8) %>...</span>
            </div>
            
            <% if (solic.observacoes) { %>
              <div class="mt-3 pt-3 border-t border-neutral-200 dark:border-neutral-700">
                <span class="text-xs font-medium text-neutral-500 block mb-1">Mensagem do Solicitante:</span>
                <p class="text-sm text-neutral-700 dark:text-neutral-300">"<%= solic.observacoes %>"</p>
              </div>
            <% } %>
          </div>

          <% if (solic.status === 'pendente') { %>
            <div class="mt-auto pt-4 flex items-center gap-3 border-t border-neutral-200 dark:border-neutral-800">
              <form action="/solicitacoes/<%= solic.id %>/recusar" method="POST" class="flex-1">
                <button type="submit" class="w-full px-4 py-2 text-sm font-medium text-red-600 bg-red-50 hover:bg-red-100 dark:text-red-400 dark:bg-red-500/10 dark:hover:bg-red-500/20 rounded-xl transition-colors">
                  Recusar
                </button>
              </form>
              <form action="/solicitacoes/<%= solic.id %>/aceitar" method="POST" class="flex-1">
                <button type="submit" class="w-full px-4 py-2 text-sm font-medium text-white bg-green-500 hover:bg-green-600 rounded-xl transition-colors shadow-sm shadow-green-500/20">
                  Aceitar Pedido
                </button>
              </form>
            </div>
          <% } %>

        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
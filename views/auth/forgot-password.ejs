<%- include('../partials/auth-header') %>
<div class="auth-screen auth-screen--form auth-screen--login">
  <%- include('../partials/auth-back-btn') %>
  <%- include('../partials/auth-hero') %>

  <section class="auth-panel">
    <div class="auth-panel__inner">
      <header class="auth-panel__header">
        <h2 class="auth-panel__title">Recuperar Senha</h2>
        <p class="auth-panel__greeting" style="color: var(--text-muted); margin-top: 10px;">Informe seu e-mail e enviaremos um link para você criar uma nova senha.</p>
      </header>

      <% if (error) { %>
        <div class="auth-alert auth-alert--error">
          <%= error %>
        </div>
      <% } else if (success) { %>
        <div class="auth-alert auth-alert--success">
          <%= success %>
        </div>
      <% } %>

      <% if (!success) { %>
        <form action="/auth/forgot-password" method="POST" class="auth-form" novalidate>
          <div class="auth-form__fields">
            <div class="auth-field">
              <label for="email" class="auth-field__label">Email:</label>
              <input
                type="email"
                id="email"
                name="email"
                maxlength="254"
                placeholder="nome@email.com"
                class="auth-field__input"
                required
                autofocus
              />
            </div>
          </div>

          <button type="submit" class="auth-btn auth-btn--mobile">
            Enviar link de recuperação
          </button>
        </form>
      <% } else { %>
        <a href="/auth/login" class="auth-btn auth-btn--outline" style="text-align: center; text-decoration: none; display: block;">Voltar para o Login</a>
      <% } %>

    </div>
  </section>
</div>

<%- include('../partials/auth-footer') %>

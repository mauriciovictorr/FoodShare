<%- include('../partials/app-shell-start') %>

<div class="app-page">
  <% if (isDoador) { %>
    <%- include('../partials/app-page-header') %>

    <article class="app-page-panel">
      <% if (itens.length === 0) { %>
        <%- include('../partials/home-empty-state', {
          variant: 'green',
          icon: 'package_2',
          title: 'Nenhuma doação publicada',
          description: 'Cadastre alimentos disponíveis para compartilhar com quem precisa.',
          actionLabel: 'Publicar primeira doação',
          actionModal: true
        }) %>
      <% } else { %>
        <div class="home-table home-table--actions">
          <div class="home-table__head">
            <span>Item</span>
            <span>Quantidade</span>
            <span class="home-table__head-date">Validade</span>
            <span>Status</span>
            <span class="home-table__head-action">Ações</span>
          </div>
          <% itens.forEach(function(item) {
            const itemExpirado = isExpired(item.validade);
          %>
            <div class="home-table__row home-table__row--clickable" data-doacao-id="<%= item.doacaoId %>" role="button" tabindex="0" aria-label="Ver detalhes de <%= item.nome %>">
              <span class="home-table__item<%= itemExpirado ? ' home-table__item--expirado' : '' %>" title="<%= item.nome %><%= itemExpirado ? ' · validade vencida' : '' %>"><%= item.nome %></span>
              <span class="home-table__qty"><%= item.quantidade %> un</span>
              <span class="home-table__date<%= itemExpirado ? ' home-table__date--expirado' : '' %>"><%= formatValidade(item.validade) %></span>
              <span class="home-pill home-pill--<%= item.displayStatus %>"><%= donationStatusLabel(item.displayStatus) %></span>
              <span class="home-table__action">
                <a href="/doacoes/<%= item.doacaoId %>/editar" class="home-table__edit">Editar</a>
              </span>
            </div>
          <% }); %>
        </div>
      <% } %>
    </article>

  <% } else { %>
    <div class="receptor-dashboard">
      <div class="receptor-dashboard__main">
        <% if (typeof query !== 'undefined' && query.solicitacao === 'ok') { %>
          <p class="solicitacao-flash" role="status">Solicitação enviada com sucesso!</p>
        <% } %>

        <div class="receptor-toolbar">
          <label class="app-search">
            <span class="app-search__icon" aria-hidden="true">
              <%- include('../partials/app-icon', { icon: 'search', size: 'header' }) %>
            </span>
            <input
              type="search"
              class="app-search__input"
              placeholder="Buscar alimentos disponíveis..."
              autocomplete="off"
              data-receptor-search
            >
          </label>

          <div class="app-filter-chips" role="group" aria-label="Filtrar por categoria">
            <% RECEPTOR_CATEGORY_FILTERS.forEach(function(cat, index) { %>
              <button
                type="button"
                class="app-filter-chip<%= index === 0 ? ' is-active' : '' %>"
                data-receptor-filter="<%= cat.key %>"
              ><%= cat.label %></button>
            <% }); %>
          </div>
        </div>

        <p class="receptor-grid-label" data-receptor-count>
          <%= doacoes.length %> <%= doacoes.length === 1 ? 'doação disponível' : 'doações disponíveis' %>
        </p>

        <% if (doacoes.length === 0) { %>
          <article class="app-page-panel receptor-empty-panel">
            <%- include('../partials/home-empty-state', {
              variant: 'blue',
              icon: 'local_mall',
              title: 'Nenhuma doação no momento',
              description: 'Volte mais tarde ou avise a comunidade sobre o FoodShare.',
              actionLabel: 'Voltar ao início',
              actionHref: '/'
            }) %>
          </article>
        <% } else { %>
          <div class="receptor-food-grid" data-receptor-grid>
            <% doacoes.forEach(function(item) { %>
              <%- include('../partials/receptor-donation-card', { item: item }) %>
            <% }); %>
          </div>

          <p class="receptor-grid-empty" data-receptor-empty hidden>
            Nenhum alimento encontrado para esta busca.
          </p>
        <% } %>
      </div>

      <aside class="receptor-dashboard__aside" aria-label="Resumo das solicitações">
        <%- include('../partials/receptor-hero-card', {
          totalSolicitadas: totalSolicitadas,
          totalRecebidas: totalRecebidas,
          totalPendentes: totalPendentes,
          mesAtual: mesAtual
        }) %>

        <article class="home-panel home-panel--requests receptor-requests-panel">
          <header class="home-panel__header">
            <h2 class="home-panel__title">Minhas solicitações</h2>
          </header>

          <% if (minhasSolicitacoes.length === 0) { %>
            <%- include('../partials/home-empty-state', {
              variant: 'amber',
              icon: 'hourglass_top',
              title: 'Nenhuma solicitação ainda',
              description: 'Quando você solicitar um item, ele aparecerá aqui com o status do pedido.'
            }) %>
          <% } else { %>
            <ul class="home-requests">
              <% minhasSolicitacoes.forEach(function(sol) {
                const pillKey = solicitationPillKey(sol.status);
                const pillLabel = solicitationPillLabel(sol.status);
              %>
                <li class="home-request home-request--readonly">
                  <div class="home-request__info">
                    <p class="home-request__title"><%= sol.itemLabel %></p>
                    <p class="home-request__meta"><%= sol.doadorNome %> · <%= timeAgo(sol.createdAt) %></p>
                  </div>
                  <span class="home-pill home-pill--<%= pillKey %>"><%= pillLabel %></span>
                </li>
              <% }); %>
            </ul>
          <% } %>
        </article>
      </aside>
    </div>

    <script src="/js/receptor-doacoes.js"></script>
  <% } %>

  <%- include('../partials/doacoes-detalhe-data') %>
</div>

<%- include('../partials/app-shell-end') %>
<%
  const err = resolveErrorPage({
    statusCode: typeof statusCode !== 'undefined' ? statusCode : (error && error.status),
    message: typeof message !== 'undefined' ? message : undefined,
    subtitle: typeof subtitle !== 'undefined' ? subtitle : undefined,
    context: typeof context !== 'undefined' ? context : undefined,
    title: typeof title !== 'undefined' ? title : undefined,
    usuario: locals.usuario,
  });
%>
<%- include('partials/error-shell-start', { title: err.pageTitle }) %>
<%- include('partials/error-page-main', { err }) %>
<%- include('partials/error-shell-end') %>

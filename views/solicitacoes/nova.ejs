<%- include('../partials/app-shell-start') %>

<div class="app-page">
  <article class="app-page-panel solicitacao-form-panel">
    <% if (errors && errors.length > 0) { %>
      <div class="auth-alert auth-alert--error" role="alert">
        <p class="auth-alert__title">Corrija os campos abaixo:</p>
        <ul class="auth-alert__list">
          <% errors.forEach(function(err) { %>
            <li><%= err.message %></li>
          <% }); %>
        </ul>
      </div>
    <% } %>

    <form method="POST" action="/solicitacoes/nova" class="solicitacao-form" id="novaSolicitacaoForm" novalidate>
      <div class="auth-field">
        <label for="solicitacao-doacao" class="auth-field__label">Pacote de doação</label>
        <select
          id="solicitacao-doacao"
          name="doacaoId"
          required
          class="auth-field__input auth-field__select<%= errors.some(function(e) { return e.field === 'doacaoId'; }) ? ' auth-field__input--error' : '' %>"
        >
          <option value="">Selecione um pacote...</option>
          <% doacoes.forEach(function(d) {
            const resumoItens = d.itens.map(function(i) { return i.nome + ' (' + i.quantidade + ')'; }).join(', ');
            const textoSelect = resumoItens.length > 60 ? resumoItens.substring(0, 60) + '...' : resumoItens;
          %>
            <option value="<%= d.id %>" <%= preSelectedDoacaoId === d.id ? 'selected' : '' %>>
              Pacote: <%= textoSelect %>
            </option>
          <% }); %>
        </select>
        <% if (doacoes.length === 0) { %>
          <span class="auth-field__hint auth-field__hint--error">Não há doações disponíveis no momento.</span>
        <% } else { %>
          <%- include('../partials/auth-field-hint', { errors: errors, field: 'doacaoId' }) %>
        <% } %>
      </div>

      <div class="auth-field">
        <label for="solicitacao-quantidade" class="auth-field__label">Quantidade solicitada</label>
        <input
          type="number"
          id="solicitacao-quantidade"
          name="quantidade"
          min="1"
          value="<%= old.quantidade || 1 %>"
          required
          class="auth-field__input<%= errors.some(function(e) { return e.field === 'quantidade'; }) ? ' auth-field__input--error' : '' %>"
        >
        <span class="auth-field__hint">Normalmente é 1, caso queira o pacote inteiro.</span>
        <%- include('../partials/auth-field-hint', { errors: errors, field: 'quantidade' }) %>
      </div>

      <div class="auth-field">
        <label for="solicitacao-observacoes" class="auth-field__label">Mensagem (opcional)</label>
        <textarea
          id="solicitacao-observacoes"
          name="observacoes"
          rows="3"
          maxlength="500"
          placeholder="Explique brevemente por que você precisa desta doação..."
          class="auth-field__input auth-field__input--textarea"
        ><%= old.observacoes || '' %></textarea>
      </div>

      <div class="solicitacao-form__actions">
        <a href="/doacoes" class="feedback-modal__btn feedback-modal__btn--secondary">Cancelar</a>
        <button
          type="submit"
          class="feedback-modal__btn feedback-modal__btn--primary"
          id="btnEnviarSolicitacao"
          <%= doacoes.length === 0 ? 'disabled' : '' %>
        >
          Enviar solicitação
        </button>
      </div>
    </form>
  </article>
</div>

<script>
  (function () {
    var form = document.getElementById('novaSolicitacaoForm');
    if (!form) return;
    form.addEventListener('submit', function () {
      var btn = document.getElementById('btnEnviarSolicitacao');
      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Enviando...';
      }
    });
  })();
</script>

<%- include('../partials/app-shell-end') %>

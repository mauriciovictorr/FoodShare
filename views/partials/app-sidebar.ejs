<aside class="app-sidebar" aria-label="Navegação principal">
  <div class="app-sidebar__top">
    <a href="/" class="app-sidebar__logo" aria-label="FoodShare">FS</a>
    <nav class="app-sidebar__nav">
      <a href="/" class="app-sidebar__link<%= activeNav === 'home' ? ' is-active' : '' %>" aria-label="Início"<%= activeNav === 'home' ? ' aria-current="page"' : '' %>>
        <%- include('app-icon', { icon: 'home', size: 'nav' }) %>
      </a>
      <a href="/doacoes" class="app-sidebar__link<%= activeNav === 'doacoes' ? ' is-active' : '' %>" aria-label="Doações"<%= activeNav === 'doacoes' ? ' aria-current="page"' : '' %>>
        <%- include('app-icon', { icon: 'redeem', size: 'nav' }) %>
      </a>
      <a href="<%= locals.usuario && (locals.usuario.role === 'doador' || locals.usuario.role === 'admin') ? '/solicitacoes/recebidas' : '/solicitacoes/minhas' %>" class="app-sidebar__link<%= activeNav === 'solicitacoes' ? ' is-active' : '' %>" aria-label="Solicitações"<%= activeNav === 'solicitacoes' ? ' aria-current="page"' : '' %>>
        <%- include('app-icon', { icon: 'front_hand', size: 'nav' }) %>
      </a>
      <a href="/historico" class="app-sidebar__link<%= activeNav === 'historico' ? ' is-active' : '' %>" aria-label="Histórico"<%= activeNav === 'historico' ? ' aria-current="page"' : '' %>>
        <%- include('app-icon', { icon: 'history', size: 'nav' }) %>
      </a>
    </nav>
  </div>
  <div class="app-sidebar__bottom">
    <a href="/configuracoes" class="app-sidebar__link<%= activeNav === 'configuracoes' ? ' is-active' : '' %>" aria-label="Configurações"<%= activeNav === 'configuracoes' ? ' aria-current="page"' : '' %>>
      <%- include('app-icon', { icon: 'settings', size: 'nav' }) %>
    </a>
    <form action="/auth/logout" method="POST" class="app-sidebar__logout">
      <button type="submit" class="app-sidebar__link" aria-label="Sair">
        <%- include('app-icon', { icon: 'logout', size: 'nav' }) %>
      </button>
    </form>
  </div>
</aside>

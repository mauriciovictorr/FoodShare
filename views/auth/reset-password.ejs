<%- include('../partials/auth-header') %>
<div class="auth-screen auth-screen--form auth-screen--login">
  <%- include('../partials/auth-hero') %>

  <section class="auth-panel">
    <div class="auth-panel__inner">
      <header class="auth-panel__header">
        <h2 class="auth-panel__title">Criar Nova Senha</h2>
        <p class="auth-panel__greeting" style="color: var(--text-muted); margin-top: 10px;">Crie uma nova senha para acessar sua conta.</p>
      </header>

      <% if (error) { %>
        <div class="auth-alert auth-alert--error">
          <%= error %>
        </div>
      <% } %>

      <form action="/auth/reset-password" method="POST" class="auth-form" novalidate>
        <input type="hidden" name="token" value="<%= token %>" />
        <div class="auth-form__fields">
          <div class="auth-field">
            <label for="senha" class="auth-field__label">Nova Senha:</label>
            <input
              type="password"
              id="senha"
              name="senha"
              maxlength="72"
              placeholder="Digite a nova senha"
              class="auth-field__input"
              required
              autofocus
            />
          </div>

          <div class="auth-field">
            <label for="confirmacaoSenha" class="auth-field__label">Confirme a Nova Senha:</label>
            <input
              type="password"
              id="confirmacaoSenha"
              name="confirmacaoSenha"
              maxlength="72"
              placeholder="Digite a mesma senha"
              class="auth-field__input"
              required
            />
          </div>
        </div>

        <button type="submit" class="auth-btn auth-btn--mobile">
          Salvar Nova Senha
        </button>
      </form>

    </div>
  </section>
</div>

<%- include('../partials/auth-footer') %>

<%- include('../partials/auth-header') %>
<div class="auth-screen auth-screen--welcome">
  <div class="auth-desktop">
    <%- include('../partials/auth-hero') %>

    <section class="auth-panel">
      <div class="auth-panel__inner">
        <header class="auth-panel__header">
          <p class="auth-panel__greeting">Seja bem vindo,</p>
          <h2 class="auth-panel__title">Entre ou crie uma conta</h2>
        </header>

        <div class="auth-welcome__actions">
          <a href="/auth/login" class="auth-btn" data-nav-direction="forward">Entrar</a>
          <a href="/auth/register" class="auth-btn auth-btn--outline" data-nav-direction="forward">Criar conta</a>
        </div>
      </div>
    </section>
  </div>

  <%- include('../partials/auth-mobile-welcome') %>
</div>
<%- include('../partials/auth-footer') %>

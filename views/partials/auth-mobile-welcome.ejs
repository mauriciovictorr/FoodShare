<section class="auth-mobile auth-mobile--welcome" aria-label="FoodShare">
  <div class="auth-mobile__decor" aria-hidden="true">
    <div class="auth-mobile__glow auth-mobile__glow--blue">
      <div class="auth-mobile__glow-spread">
        <img src="/images/auth/ellipse-1.svg" alt="">
      </div>
    </div>
    <div class="auth-mobile__glow auth-mobile__glow--green">
      <div class="auth-mobile__glow-spread">
        <img src="/images/auth/ellipse-2.svg" alt="">
      </div>
    </div>
    <div class="auth-mobile__star-wrap">
      <div class="auth-mobile__star-spread">
        <img src="/images/auth/star.svg" alt="">
      </div>
    </div>
  </div>

  <h1 class="auth-mobile__logo">
    <span class="auth-mobile__logo-food">Food</span><span class="auth-mobile__logo-share">Share</span>
  </h1>

  <div class="auth-mobile__bottom">
    <div class="auth-mobile__tagline">
      <p class="auth-mobile__tagline-dark">Doe o que sobra.</p>
      <p class="auth-mobile__tagline-green">Alimente quem precisa.</p>
    </div>

    <div class="auth-welcome__actions">
      <a href="/auth/login" class="auth-btn auth-btn--mobile" data-nav-direction="forward">Entrar</a>
      <a href="/auth/register" class="auth-btn auth-btn--outline auth-btn--mobile" data-nav-direction="forward">Criar conta</a>
    </div>
  </div>
</section>

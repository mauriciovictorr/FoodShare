<%- include('../partials/app-shell-start') %>

<div class="app-page">
  <article class="app-page-panel">
    <% if (solicitacoes.length === 0) { %>
      <%- include('../partials/home-empty-state', {
        variant: 'amber',
        icon: 'mark_email_unread',
        title: 'Nenhuma solicitação recebida',
        description: 'Quando alguém pedir um dos seus itens, o pedido aparece aqui para você aceitar ou recusar.',
        actionLabel: 'Ver minhas doações',
        actionHref: '/doacoes'
      }) %>
    <% } else { %>
      <div class="solicitacoes-toolbar">
        <p class="solicitacoes-toolbar__count" data-solicitacoes-count>
          <%= solicitacoes.length %> <%= solicitacoes.length === 1 ? 'pedido' : 'pedidos' %>
        </p>
        <div class="app-filter-chips solicitacoes-filters" role="group" aria-label="Filtrar pedidos">
          <button type="button" class="app-filter-chip is-active" data-solicitacao-filter="todos">Todos</button>
          <button type="button" class="app-filter-chip" data-solicitacao-filter="pendente">Pendentes</button>
          <button type="button" class="app-filter-chip" data-solicitacao-filter="aprovado">Aprovados</button>
          <button type="button" class="app-filter-chip" data-solicitacao-filter="recusado">Recusados</button>
          <button type="button" class="app-filter-chip" data-solicitacao-filter="cancelado">Cancelados</button>
        </div>
      </div>

      <ul class="home-requests" data-solicitacoes-list>
        <% solicitacoes.forEach(function(solic) {
          const itemLabel = solic.doacao.itens && solic.doacao.itens[0]
            ? solic.doacao.itens[0].nome
            : 'Doação';
          const pillLabel = solicitationPillLabel(solic.status);
          const pillKey = solicitationPillKey(solic.status);
        %>
          <li
            class="home-request home-request--readonly home-request--clickable"
            data-solicitacao-id="<%= solic.id %>"
            data-status="<%= solic.status %>"
            role="button"
            tabindex="0"
            aria-label="Ver detalhes do pedido de <%= itemLabel %>"
          >
            <div class="home-request__info">
              <p class="home-request__title"><%= itemLabel %> · <%= solic.quantidade %> un</p>
              <p class="home-request__meta">
                <%= solic.usuario.nome %> · <%= timeAgo(solic.createdAt) %>
                <% if (solic.observacoes) { %> · "<%= solic.observacoes %>"<% } %>
              </p>
            </div>
            <div class="home-request__aside">
              <span class="home-pill home-pill--<%= pillKey %>"><%= pillLabel %></span>
            </div>
          </li>
        <% }); %>
      </ul>

      <p class="solicitacoes-filter-empty" data-solicitacoes-filter-empty hidden>
        Nenhum pedido neste filtro.
      </p>
    <% } %>
  </article>
</div>

<%- include('../partials/solicitacoes-detalhe-data') %>
<%- include('../partials/solicitacao-detail-modal') %>
<script src="/js/solicitacoes-recebidas.js"></script>

<%- include('../partials/app-shell-end') %>

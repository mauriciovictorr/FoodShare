<%- include('../partials/app-shell-start') %>

<div class="app-page">
  <% if (isDoador) { %>
    <%- include('../partials/app-page-header') %>

    <article class="app-page-panel">
      <% if (itens.length === 0) { %>
        <%- include('../partials/home-empty-state', {
          variant: 'green',
          icon: 'package_2',
          title: 'Nenhuma doação publicada',
          description: 'Cadastre alimentos disponíveis para compartilhar com quem precisa.',
          actionLabel: 'Publicar primeira doação',
          actionModal: true
        }) %>
      <% } else { %>
        <div class="home-table">
          <div class="home-table__head">
            <span>item</span>
            <span>quantidade</span>
            <span>validade</span>
            <span>status</span>
          </div>
          <% itens.forEach(function(item) { %>
            <div class="home-table__row">
              <span class="home-table__item"><%= item.nome %></span>
              <span class="home-table__qty"><%= item.quantidade %> un</span>
              <span class="home-table__date"><%= formatValidade(item.validade) %></span>
              <span class="home-pill home-pill--<%= item.displayStatus %>"><%= item.displayStatus %></span>
            </div>
          <% }); %>
        </div>
      <% } %>
    </article>

  <% } else { %>
    <% if (doacoes.length === 0) { %>
      <article class="app-page-panel">
        <%- include('../partials/home-empty-state', {
          variant: 'blue',
          icon: 'local_mall',
          title: 'Nenhuma doação no momento',
          description: 'Volte mais tarde ou avise a comunidade sobre o FoodShare.',
          actionLabel: 'Voltar ao início',
          actionHref: '/'
        }) %>
      </article>
    <% } else { %>
      <div class="app-donation-grid">
        <% doacoes.forEach(function(doacao) { %>
          <article class="app-donation-card">
            <div class="app-donation-card__top">
              <p class="app-donation-card__donor">
                Doador: <strong><%= doacao.usuario.nome %></strong>
              </p>
              <span class="app-donation-card__date"><%= formatDateShort(doacao.createdAt) %></span>
            </div>

            <div class="app-donation-card__items">
              <div class="app-donation-card__items-head">
                <span>Itens inclusos</span>
                <span class="app-donation-card__items-count"><%= doacao.itens.length %> itens</span>
              </div>
              <% doacao.itens.forEach(function(item) { %>
                <div class="app-donation-card__item">
                  <span><%= item.nome %></span>
                  <span class="app-donation-card__item-meta">
                    <%= item.quantidade %> un · Val: <%= formatValidade(item.validade) %>
                  </span>
                </div>
              <% }); %>
              <% if (doacao.observacoes) { %>
                <p class="app-donation-card__note">"<%= doacao.observacoes %>"</p>
              <% } %>
            </div>

            <a href="/solicitacoes/nova?doacaoId=<%= doacao.id %>" class="app-donation-card__action">
              Solicitar este pacote
            </a>
          </article>
        <% }); %>
      </div>
    <% } %>
  <% } %>
</div>

<%- include('../partials/app-shell-end') %>

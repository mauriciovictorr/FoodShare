<%- include('../partials/header') %>

<div class="max-w-xl mx-auto px-4 py-8">
  <div class="bg-white dark:bg-[#111111] rounded-2xl border border-neutral-200 dark:border-neutral-800 p-6 shadow-sm">
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-neutral-900 dark:text-white mb-1">Solicitar Alimentos</h1>
      <p class="text-neutral-500 text-sm">Escolha um dos pacotes de doação disponíveis.</p>
    </div>
    <% if (errors && errors.length > 0) { %>
      <div class="bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-red-600 dark:text-red-400 p-4 rounded-xl mb-6">
        <ul class="list-disc list-inside text-sm">
          <% errors.forEach(err => { %>
            <li><%= err.message %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form method="POST" action="/solicitacoes/nova">
      <div class="mb-4">
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Pacote de Doação *</label>
        <select name="doacaoId" required class="w-full bg-white dark:bg-[#1a1a1a] border border-neutral-300 dark:border-neutral-700 rounded-xl px-4 py-3 text-sm text-neutral-900 dark:text-white focus:ring-2 focus:ring-green-500 focus:border-green-500">
          <option value="">Selecione um pacote...</option>
          <% doacoes.forEach(d => { %>
            <% 
              // Monta um resumo do pacote: "Arroz (5), Feijão (2)..."
              const resumoItens = d.itens.map(i => `${i.nome} (${i.quantidade})`).join(', ');
              const textoSelect = resumoItens.length > 60 ? resumoItens.substring(0, 60) + '...' : resumoItens;
            %>
            <option value="<%= d.id %>" <%= preSelectedDoacaoId === d.id ? 'selected' : '' %>>
              Pacote: <%= textoSelect %>
            </option>
          <% }) %>
        </select>
        <% if (doacoes.length === 0) { %>
          <p class="text-xs text-red-500 mt-2">Não há doações disponíveis no momento.</p>
        <% } %>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Quantos pacotes/itens deste doador você precisa? *</label>
        <input type="number" name="quantidade" min="1" value="<%= old.quantidade || 1 %>" required class="w-full bg-white dark:bg-[#1a1a1a] border border-neutral-300 dark:border-neutral-700 rounded-xl px-4 py-3 text-sm text-neutral-900 dark:text-white focus:ring-2 focus:ring-green-500">
        <p class="text-xs text-neutral-500 mt-1">Normalmente é 1, caso queira o pacote inteiro.</p>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-2">Mensagem (Opcional)</label>
        <textarea name="observacoes" rows="3" class="w-full bg-transparent border border-neutral-300 dark:border-neutral-700 rounded-xl px-4 py-3 text-sm text-neutral-900 dark:text-white focus:ring-2 focus:ring-green-500 focus:border-green-500" placeholder="Explique brevemente por que você precisa desta doação..."><%= old.observacoes || '' %></textarea>
      </div>

      <div class="pt-4 border-t border-neutral-200 dark:border-neutral-800 flex justify-end gap-3">
        <a href="/doacoes" class="px-5 py-2.5 text-sm font-medium text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors">Cancelar</a>
        <button type="submit" class="px-5 py-2.5 bg-green-500 hover:bg-green-600 text-white text-sm font-medium rounded-xl shadow-lg shadow-green-500/20 transition-all hover:-translate-y-0.5" <%= doacoes.length === 0 ? 'disabled' : '' %>>
          Enviar Solicitação
        </button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
<%- include('../partials/header') %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-neutral-900 dark:text-white mb-1">Minhas Solicitações</h1>
    <p class="text-neutral-500 text-sm">Acompanhe o status dos alimentos que você solicitou.</p>
  </div>

  <% if (solicitacoes.length === 0) { %>
    <div class="bg-neutral-50 dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700 rounded-2xl p-12 text-center">
      <div class="w-16 h-16 bg-neutral-100 dark:bg-neutral-800 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
        🙏
      </div>
      <h3 class="text-lg font-medium text-neutral-900 dark:text-white mb-2">Nenhuma solicitação encontrada</h3>
      <p class="text-neutral-500 text-sm mb-6">Você ainda não solicitou nenhuma doação.</p>
      <a href="/doacoes" class="px-5 py-2.5 bg-green-500 hover:bg-green-600 text-white text-sm font-medium rounded-xl transition-colors">
        Ver Doações Disponíveis
      </a>
    </div>
  <% } else { %>
    <div class="space-y-4">
      <% solicitacoes.forEach(solic => { %>
        <div class="bg-white dark:bg-[#111111] border border-neutral-200 dark:border-neutral-800 rounded-2xl p-5 shadow-sm flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          
          <div>
            <div class="flex items-center gap-3 mb-2">
              <span class="px-2.5 py-0.5 rounded-full text-xs font-medium border
                <%= solic.status === 'pendente' ? 'bg-yellow-50 text-yellow-700 border-yellow-200 dark:bg-yellow-500/10 dark:text-yellow-400 dark:border-yellow-500/20' : '' %>
                <%= solic.status === 'aprovado' ? 'bg-green-50 text-green-700 border-green-200 dark:bg-green-500/10 dark:text-green-400 dark:border-green-500/20' : '' %>
                <%= solic.status === 'recusado' ? 'bg-red-50 text-red-700 border-red-200 dark:bg-red-500/10 dark:text-red-400 dark:border-red-500/20' : '' %>
                <%= solic.status === 'cancelado' ? 'bg-neutral-100 text-neutral-600 border-neutral-300 dark:bg-neutral-800 dark:text-neutral-400 dark:border-neutral-700' : '' %>
              ">
                <%= solic.status.charAt(0).toUpperCase() + solic.status.slice(1) %>
              </span>
              <span class="text-xs text-neutral-400"><%= new Date(solic.createdAt).toLocaleDateString() %></span>
            </div>
            
            <h3 class="font-medium text-neutral-900 dark:text-white text-sm mb-1">
              ID do Pacote Solicitado: <span class="text-neutral-500 font-mono text-xs"><%= solic.doacao.id.substring(0,8) %>...</span>
            </h3>
            
            <% if (solic.observacoes) { %>
              <p class="text-xs text-neutral-500 mt-2">Sua mensagem: "<%= solic.observacoes %>"</p>
            <% } %>
          </div>

          <div class="flex items-center gap-3 mt-4 sm:mt-0">
            <% if (solic.status === 'pendente') { %>
              <form action="/solicitacoes/<%= solic.id %>/cancelar" method="POST">
                <button type="submit" class="px-4 py-2 text-xs font-medium text-red-600 bg-red-50 hover:bg-red-100 dark:text-red-400 dark:bg-red-500/10 dark:hover:bg-red-500/20 rounded-lg transition-colors">
                  Cancelar Pedido
                </button>
              </form>
            <% } %>
          </div>

        </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>

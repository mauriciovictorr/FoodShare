<%- include('partials/app-shell-start') %>

<%
  const semImpacto = isDoador && stats.familiasAjudadas === 0;
  const semDoacoes = isDoador && stats.totalDoacoes === 0;
  const semAtivas = isDoador && stats.doacoesAtivas === 0;
  const semPendentes = stats.solicitacoesPendentes === 0;
  const hintDoacoes = isDoador
    ? (semDoacoes ? 'Publique seu primeiro item' : (semAtivas ? 'Nenhuma doação ativa no momento' : stats.doacoesAtivas + ' ativas agora'))
    : (stats.doacoesAtivas === 0 ? 'Você ainda não solicitou nada' : stats.solicitacoesPendentes + ' pendentes');
  const hintPendentes = isDoador
    ? (semPendentes ? 'Nenhum pedido aguardando resposta' : 'Aguardando sua resposta')
    : (semPendentes ? 'Nenhuma solicitação em análise' : 'Em análise');
%>

<div class="home-dashboard">
  <section class="home-metrics" aria-label="Resumo">
    <% if (isDoador) { %>
      <article class="home-hero-card<%= semImpacto ? ' home-hero-card--empty' : '' %>">
        <div class="home-hero-card__text">
          <% if (semImpacto) { %>
            <p class="home-hero-card__title">Seu impacto começa agora!</p>
            <p class="home-hero-card__subtitle">Faça uma doação e acompanhe quantas famílias você alcança em <%= mesAtual %>.</p>
          <% } else { %>
            <p class="home-hero-card__title">Você ajudou</p>
            <p class="home-hero-card__title"><%= stats.familiasAjudadas %> famílias em <%= mesAtual %>!</p>
            <p class="home-hero-card__subtitle">Continue doando, cada item conta.</p>
          <% } %>
        </div>
        <button type="button" class="home-hero-card__btn" data-doacao-modal-open>
          <%= semImpacto ? 'Começar a doar' : 'Fazer uma nova doação' %>
          <%- include('partials/app-svg-icon', { src: '/images/app/icon-arrow-right.svg', size: 'arrow' }) %>
        </button>
      </article>
    <% } else { %>
      <article class="home-hero-card">
        <div class="home-hero-card__text">
          <p class="home-hero-card__title">Bem-vindo ao</p>
          <p class="home-hero-card__title">FoodShare!</p>
          <p class="home-hero-card__subtitle">Encontre doações disponíveis na sua comunidade.</p>
        </div>
        <a href="/doacoes" class="home-hero-card__btn">
          Ver doações disponíveis
          <%- include('partials/app-svg-icon', { src: '/images/app/icon-arrow-right.svg', size: 'arrow' }) %>
        </a>
      </article>
    <% } %>

    <div class="home-metrics__row">
      <article class="home-metric-card<%= semDoacoes || (!isDoador && stats.doacoesAtivas === 0) ? ' home-metric-card--empty' : '' %>">
        <div class="home-metric-card__icon home-metric-card__icon--green">
          <%- include('partials/app-svg-icon', { src: '/images/app/icon-gift-metric.svg', size: 'metric' }) %>
        </div>
        <div class="home-metric-card__body">
          <p class="home-metric-card__label"><%= isDoador ? 'Minhas doações' : 'Minhas solicitações' %></p>
          <p class="home-metric-card__value<%= (isDoador ? stats.totalDoacoes : stats.doacoesAtivas) === 0 ? ' home-metric-card__value--zero' : '' %>"><%= isDoador ? stats.totalDoacoes : stats.doacoesAtivas %></p>
          <p class="home-metric-card__hint"><%= hintDoacoes %></p>
        </div>
      </article>

      <article class="home-metric-card<%= semPendentes ? ' home-metric-card--empty' : '' %>">
        <div class="home-metric-card__icon home-metric-card__icon--amber">
          <%- include('partials/app-svg-icon', { src: '/images/app/icon-hand-metric.svg', size: 'metric' }) %>
        </div>
        <div class="home-metric-card__body">
          <p class="home-metric-card__label"><%= isDoador ? 'Solicitações pendentes' : 'Aguardando resposta' %></p>
          <p class="home-metric-card__value<%= stats.solicitacoesPendentes === 0 ? ' home-metric-card__value--zero' : '' %>"><%= stats.solicitacoesPendentes %></p>
          <p class="home-metric-card__hint"><%= hintPendentes %></p>
        </div>
      </article>
    </div>
  </section>

  <section class="home-panels">
    <% if (isDoador) { %>
      <article class="home-panel home-panel--table">
        <header class="home-panel__header">
          <h2 class="home-panel__title">Minhas doações ativas</h2>
          <a href="/doacoes" class="home-panel__action" aria-label="Ver todas as doações">
            <%- include('partials/app-svg-icon', { src: '/images/app/icon-chevron-right.svg', size: 'panel' }) %>
          </a>
        </header>

        <% if (doacoesAtivas.length === 0) { %>
          <%- include('partials/home-empty-state', {
            variant: 'green',
            icon: 'add_box',
            title: 'Nada publicado ainda',
            description: 'Cadastre alimentos disponíveis e acompanhe validade e status de cada item nesta tabela.',
            actionLabel: 'Publicar primeira doação',
            actionModal: true
          }) %>
        <% } else { %>
          <div class="home-table">
            <div class="home-table__head">
              <span>Item</span>
              <span>Quantidade</span>
              <span class="home-table__head-date">Validade</span>
              <span>Status</span>
            </div>
            <% doacoesAtivas.forEach(function(doacao) {
              const itemExpirado = isExpired(doacao.validade);
            %>
              <div class="home-table__row home-table__row--clickable" data-doacao-id="<%= doacao.doacaoId %>" role="button" tabindex="0" aria-label="Ver detalhes de <%= doacao.nome %>">
                <span class="home-table__item<%= itemExpirado ? ' home-table__item--expirado' : '' %>" title="<%= doacao.nome %><%= itemExpirado ? ' · validade vencida' : '' %>"><%= doacao.nome %></span>
                <span class="home-table__qty"><%= doacao.quantidade %> un</span>
                <span class="home-table__date<%= itemExpirado ? ' home-table__date--expirado' : '' %>"><%= formatValidade(doacao.validade) %></span>
                <span class="home-pill home-pill--<%= doacao.displayStatus %>"><%= donationStatusLabel(doacao.displayStatus) %></span>
              </div>
            <% }); %>
          </div>
        <% } %>
      </article>

      <article class="home-panel home-panel--requests">
        <header class="home-panel__header">
          <h2 class="home-panel__title">Solicitações recebidas</h2>
        </header>

        <% if (solicitacoesRecebidas.length === 0) { %>
          <%- include('partials/home-empty-state', {
            variant: 'amber',
            icon: 'inbox',
            title: 'Nenhuma solicitação por enquanto',
            description: 'Quando alguém pedir um dos seus itens, o pedido aparece aqui para você aceitar ou recusar.'
          }) %>
        <% } else { %>
          <ul class="home-requests" data-solicitacoes-list>
            <% solicitacoesRecebidas.forEach(function(solic) {
              const pillKey = solicitationPillKey(solic.status);
              const pillLabel = solicitationPillLabel(solic.status);
            %>
              <li
                class="home-request home-request--readonly home-request--clickable"
                data-solicitacao-id="<%= solic.id %>"
                data-status="<%= solic.status %>"
                role="button"
                tabindex="0"
                aria-label="Ver detalhes do pedido de <%= solic.itemLabel %>"
              >
                <div class="home-request__info">
                  <p class="home-request__title"><%= solic.itemLabel %></p>
                  <p class="home-request__meta"><%= solic.usuario.nome %> · <%= timeAgo(solic.createdAt) %></p>
                </div>
                <div class="home-request__aside">
                  <span class="home-pill home-pill--<%= pillKey %>"><%= pillLabel %></span>
                </div>
              </li>
            <% }); %>
          </ul>
        <% } %>
      </article>
    <% } else { %>
      <article class="home-panel home-panel--full">
        <header class="home-panel__header">
          <h2 class="home-panel__title">Doações disponíveis</h2>
          <a href="/doacoes" class="home-panel__action" aria-label="Ver todas">
            <%- include('partials/app-svg-icon', { src: '/images/app/icon-chevron-right.svg', size: 'panel' }) %>
          </a>
        </header>
        <%- include('partials/home-empty-state', {
          variant: 'blue',
          icon: 'explore',
          title: 'Ainda não há doações por aqui',
          description: 'Assim que a comunidade publicar itens, eles aparecerão para você solicitar o que precisar.',
          actionLabel: 'Explorar doações',
          actionHref: '/doacoes'
        }) %>
      </article>
    <% } %>
  </section>
</div>

<%- include('partials/doacoes-detalhe-data') %>
<% if (isDoador && typeof solicitacoesDetalhe !== 'undefined' && Object.keys(solicitacoesDetalhe).length) { %>
  <%- include('partials/solicitacoes-detalhe-data') %>
  <%- include('partials/solicitacao-detail-modal') %>
  <script src="/js/solicitacoes-recebidas.js"></script>
<% } %>

<%- include('partials/app-shell-end') %>